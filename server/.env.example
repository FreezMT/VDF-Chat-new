NODE_ENV=development
PORT=4000
# SQLite (удобно на Windows без установки PostgreSQL):
DATABASE_URL="file:./dev.db"
# PostgreSQL (Docker / прод):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vdf_chat
REDIS_URL=
JWT_ACCESS_SECRET=change-me-access-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-min-16-chars
# Для телефона в той же Wi‑Fi: добавьте URL через запятую, см. README клиента
CLIENT_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:4000
UPLOAD_DIR=uploads
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@vdf.local
SEED_ADMIN_EMAIL=admin@vdf.local
SEED_ADMIN_PASSWORD=adminadmin
